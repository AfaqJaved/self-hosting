# SurrealDB
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook
SURREAL_URL=ws://surrealdb:8000/rpc
SURREAL_LOG_LEVEL=info
SURREAL_DB_PATH=rocksdb:/mydata/mydatabase.db

# Open Notebook
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-to-a-secret-string

# Volume paths
DB_VOLUME_PATH=/home/afaqjaved/docker-volumes/open-notebook-llm/db
NOTEBOOK_VOLUME_PATH=/home/afaqjaved/docker-volumes/open-notebook-llm/notebook

# Ports
SURREAL_PORT=8000
NOTEBOOK_UI_PORT=8502
NOTEBOOK_API_PORT=5055
API_URL=https://notebookapi.afaqjaved.com
